{
  "id": "prowlarr-torrent-provider",
  "name": "Prowlarr Torrent Provider",
  "version": "1.1.0",
  "manifestURI": "https://raw.githubusercontent.com/isoura4/Seanime_Torrent_Prowlarr/main/prowlarr-torrent-provider.json",
  "language": "typescript",
  "type": "anime-torrent-provider",
  "description": "Recherche des torrents anime via les indexeurs configurés dans Prowlarr.",
  "author": "isoura4",
  "icon": "",
  "lang": "multi",
  "payloadURI": "https://raw.githubusercontent.com/isoura4/Seanime_Torrent_Prowlarr/main/prowlarr-anime-torrent-provider.ts",
  "website": "https://prowlarr.com",
  "plugin": {
    "version": "1",
    "permissions": {}
  },
  "userConfig": {
    "requiresConfig": true,
    "version": 1,
    "fields": [
      {
        "name": "prowlarrBaseUrl",
        "label": "Prowlarr Base URL",
        "type": "text",
        "default": "http://localhost:9696"
      },
      {
        "name": "prowlarrApiKey",
        "label": "Prowlarr API Key",
        "type": "text",
        "default": ""
      },
      {
        "name": "indexerIds",
        "label": "Indexer IDs (comma-separated, optional)",
        "type": "text",
        "default": ""
      },
      {
        "name": "resultLimit",
        "label": "Maximum results",
        "type": "text",
        "default": "50"
      }
    ]
  }
}
